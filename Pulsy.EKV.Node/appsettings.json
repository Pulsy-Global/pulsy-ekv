{
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://localhost:8080",
        "Protocols": "Http2"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Node": {
    "DataPath": "data",
    "GrpcEndpoint": "http://localhost:8080"
  },
  "Nats": {
    "Url": "nats://localhost:4222"
  },
  "Pool": {
    "MaxOpen": 100,
    "IdleTimeoutSeconds": 300,
    "Compression": "lz4",
    "L0MaxSsts": 64,
    "L0SstSizeBytes": 33554432,
    "MaxUnflushedBytes": 134217728,
    "WalEnabled": true,
    "AwaitDurable": false,
    "ManifestPollIntervalSeconds": 30,
    "CompactorPollIntervalSeconds": 30,
    "Compactor": {
      "MaxConcurrentCompactions": 2
    },
    "BloomFilter": {
      "BitsPerKey": 16
    },
    "DiskCache": {
      "Enabled": true,
      "RootFolder": "data/cache",
      "MaxSizeMb": null,
      "TotalDiskBudgetMb": 10240,
      "CachePuts": true,
      "PreloadL0": true
    }
  },
  "Cluster": {
    "LeaseTtlSeconds": 30,
    "LeaseRenewSeconds": 20,
    "StatusTtlSeconds": 15,
    "StatusIntervalSeconds": 10
  },
  "Backends": {
    "default": {
      "Type": "Local"
    }
  },
  "Limits": {
    "MaxValueBytes": 409600,
    "MaxKeyBytes": 512
  }
}
