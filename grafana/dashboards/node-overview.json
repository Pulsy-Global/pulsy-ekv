{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus" },
        "query": "label_values(ekv_pool_open{job=\"ekv\"}, instance)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Node Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Open Namespaces",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "ekv_pool_open{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Owned Namespaces",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "ekv_namespaces_owned{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Disk Free",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "ekv_disk_free_bytes{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Pool Evictions (total)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "ekv_pool_evictions_total{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "gRPC per Node",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "title": "Request Rate by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_request_duration_seconds_count{job=\"ekv\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Request Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{job=\"ekv\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "title": "Latency p50 by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (job, le) (rate(http_server_request_duration_seconds_bucket{job=\"ekv\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Latency p95 by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_request_duration_seconds_bucket{job=\"ekv\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Latency p99 by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_server_request_duration_seconds_bucket{job=\"ekv\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Leases per Node",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "title": "Lease Acquired Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(ekv_lease_acquired_total{job=\"ekv\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Lease Renewed Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(ekv_lease_renewed_total{job=\"ekv\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Lease Lost Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "expr": "rate(ekv_lease_lost_total{job=\"ekv\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "SlateDB per Node",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "title": "Get Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(slatedb_get_requests{job=\"ekv\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Write Ops",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(slatedb_write_ops{job=\"ekv\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "slatedb_total_mem_size_bytes{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} mem"
        },
        {
          "expr": "slatedb_wal_buffer_estimated_bytes{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} WAL"
        }
      ]
    },
    {
      "title": "L0 SST Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "slatedb_l0_sst_count{job=\"ekv\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Block Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 42 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(slatedb_cache_data_block_hit{job=\"ekv\",instance=~\"$instance\"}[1m]) / (rate(slatedb_cache_data_block_hit{job=\"ekv\",instance=~\"$instance\"}[1m]) + rate(slatedb_cache_data_block_miss{job=\"ekv\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} data"
        },
        {
          "expr": "rate(slatedb_cache_index_hit{job=\"ekv\",instance=~\"$instance\"}[1m]) / (rate(slatedb_cache_index_hit{job=\"ekv\",instance=~\"$instance\"}[1m]) + rate(slatedb_cache_index_miss{job=\"ekv\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} index"
        }
      ]
    },
    {
      "title": "Backpressure Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 42 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "expr": "rate(slatedb_backpressure_count{job=\"ekv\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Namespaces",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "collapsed": false
    },
    {
      "title": "Namespace Breakdown",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 51 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Ops/s" },
            "properties": [{ "id": "unit", "value": "ops" }]
          },
          {
            "matcher": { "id": "byName", "options": "Size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Scan items/s" },
            "properties": [{ "id": "unit", "value": "ops" }]
          },
          {
            "matcher": { "id": "byName", "options": "Slow (5m)" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Ops/s", "desc": true }]
      },
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "namespace": "Namespace",
              "Value #A": "Ops/s",
              "Value #B": "Slow (5m)",
              "Value #C": "Size",
              "Value #D": "Scan items/s"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (namespace) (rate(ekv_ops_total{job=\"ekv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (namespace) (increase(ekv_slow_requests_total{job=\"ekv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "sum by (namespace) (ekv_namespace_size_bytes{job=\"ekv\",instance=~\"$instance\"})",
          "legendFormat": "{{namespace}}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "sum by (namespace) (rate(ekv_scan_items_total{job=\"ekv\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "format": "table",
          "instant": true,
          "refId": "D"
        }
      ]
    },
    {
      "title": "Request Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 61 },
      "collapsed": false
    },
    {
      "title": "Latency by Method (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (method, le) (rate(ekv_request_duration_seconds_bucket{job=\"ekv\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "title": "Latency by Method (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (method, le) (rate(ekv_request_duration_seconds_bucket{job=\"ekv\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{method}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ekv", "nodes"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EKV Node Overview",
  "uid": "ekv-node-overview",
  "version": 1
}
